# Next Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                                # openssl rand -base64 32

# GitHub OAuth — https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Sepolia RPC — Alchemy free tier: https://dashboard.alchemy.com
NEXT_PUBLIC_SEPOLIA_RPC=

# WalletConnect Project ID — https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Deploy-time only — fresh wallet, never your main wallet
# Fund with Sepolia ETH: https://www.alchemy.com/faucets/ethereum-sepolia
DEPLOYER_PRIVATE_KEY=

# For forge --verify flag — https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Fill after forge deploy
NEXT_PUBLIC_REGISTRY_ADDRESS=
